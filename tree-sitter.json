{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "gum",
      "camelcase": "GUM",
      "title": "gum",
      "scope": "source.gum",
      "file-types": [
        "gum,",
        "gin"
      ],
      "injection-regex": "^gum$",
      "class-name": "TreeSitterGUM"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Parser for .gum and .gin files used in PLASIMO",
    "authors": [
      {
        "name": "Jan Kuhfeld",
        "email": "jankuhfeld@plasma-matters.nl"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-gum"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}
