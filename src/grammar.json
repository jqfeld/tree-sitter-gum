{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "gum",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_statement"
      }
    },
    "_statement": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "block"
        },
        {
          "type": "SYMBOL",
          "name": "declare"
        },
        {
          "type": "SYMBOL",
          "name": "include"
        },
        {
          "type": "SYMBOL",
          "name": "key_value"
        }
      ]
    },
    "block": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "key",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_statement"
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "key_value": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "key",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "FIELD",
          "name": "value",
          "content": {
            "type": "SYMBOL",
            "name": "_value"
          }
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "FIELD",
            "name": "extra",
            "content": {
              "type": "SYMBOL",
              "name": "_extra_value"
            }
          }
        }
      ]
    },
    "_extra_value": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "named_constant"
        },
        {
          "type": "SYMBOL",
          "name": "quantity"
        },
        {
          "type": "SYMBOL",
          "name": "paren_expr"
        },
        {
          "type": "SYMBOL",
          "name": "env_path"
        }
      ]
    },
    "declare": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_declare_kw"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "bare_identifier"
          }
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "FIELD",
          "name": "value",
          "content": {
            "type": "SYMBOL",
            "name": "_value"
          }
        }
      ]
    },
    "_declare_kw": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": "Declare"
          },
          {
            "type": "STRING",
            "value": "_Declare"
          }
        ]
      }
    },
    "include": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "Include"
        },
        {
          "type": "FIELD",
          "name": "path",
          "content": {
            "type": "SYMBOL",
            "name": "include_path"
          }
        }
      ]
    },
    "include_path": {
      "type": "PATTERN",
      "value": "[^\\s{}\"]+"
    },
    "_value": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "named_constant"
        },
        {
          "type": "SYMBOL",
          "name": "quantity"
        },
        {
          "type": "SYMBOL",
          "name": "paren_expr"
        },
        {
          "type": "SYMBOL",
          "name": "env_path"
        },
        {
          "type": "SYMBOL",
          "name": "bare_value"
        }
      ]
    },
    "quantity": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "number"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SEQ",
                  "members": [
                    {
                      "type": "STRING",
                      "value": "*"
                    },
                    {
                      "type": "SYMBOL",
                      "name": "unit_expr"
                    }
                  ]
                },
                {
                  "type": "SEQ",
                  "members": [
                    {
                      "type": "STRING",
                      "value": "/"
                    },
                    {
                      "type": "SYMBOL",
                      "name": "unit_expr"
                    }
                  ]
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "number": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[+-]?(\\d+\\.?\\d*|\\.\\d+)([eE][+-]?\\d+)?"
      }
    },
    "unit_expr": {
      "type": "SYMBOL",
      "name": "_unit_term"
    },
    "_unit_term": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "unit_div"
        },
        {
          "type": "SYMBOL",
          "name": "unit_mul"
        },
        {
          "type": "SYMBOL",
          "name": "unit_power"
        },
        {
          "type": "SYMBOL",
          "name": "unit_func"
        },
        {
          "type": "SYMBOL",
          "name": "unit_group"
        },
        {
          "type": "SYMBOL",
          "name": "unit_neg"
        },
        {
          "type": "SYMBOL",
          "name": "unit_add"
        },
        {
          "type": "SYMBOL",
          "name": "unit_num"
        },
        {
          "type": "SYMBOL",
          "name": "unit_atom"
        }
      ]
    },
    "unit_div": {
      "type": "PREC_LEFT",
      "value": 1,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "SYMBOL",
            "name": "_unit_term"
          },
          {
            "type": "STRING",
            "value": "/"
          },
          {
            "type": "SYMBOL",
            "name": "_unit_term"
          }
        ]
      }
    },
    "unit_mul": {
      "type": "PREC_LEFT",
      "value": 2,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "SYMBOL",
            "name": "_unit_term"
          },
          {
            "type": "STRING",
            "value": "*"
          },
          {
            "type": "SYMBOL",
            "name": "_unit_term"
          }
        ]
      }
    },
    "unit_add": {
      "type": "PREC_LEFT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "SYMBOL",
            "name": "_unit_term"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "STRING",
                "value": "+"
              },
              {
                "type": "STRING",
                "value": "-"
              }
            ]
          },
          {
            "type": "SYMBOL",
            "name": "_unit_term"
          }
        ]
      }
    },
    "unit_power": {
      "type": "PREC",
      "value": 3,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "SYMBOL",
            "name": "_unit_term"
          },
          {
            "type": "STRING",
            "value": "^"
          },
          {
            "type": "SYMBOL",
            "name": "unit_exponent"
          }
        ]
      }
    },
    "unit_func": {
      "type": "PREC",
      "value": 5,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "SYMBOL",
            "name": "unit_atom"
          },
          {
            "type": "SYMBOL",
            "name": "unit_group"
          }
        ]
      }
    },
    "unit_group": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "SYMBOL",
          "name": "_unit_term"
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "unit_neg": {
      "type": "PREC",
      "value": 4,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "-"
          },
          {
            "type": "SYMBOL",
            "name": "_unit_term"
          }
        ]
      }
    },
    "unit_num": {
      "type": "PATTERN",
      "value": "\\d+\\.?\\d*([eE][+-]?\\d+)?"
    },
    "unit_atom": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "PATTERN",
            "value": "[A-Za-z_Ω°μ][A-Za-z_0-9Ω°μ]*"
          },
          {
            "type": "PATTERN",
            "value": "['`][A-Za-z_][A-Za-z_0-9]*"
          }
        ]
      }
    },
    "unit_exponent": {
      "type": "PATTERN",
      "value": "[+-]?(\\d+\\.?\\d*|\\.\\d+)"
    },
    "named_constant": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": "'"
              },
              {
                "type": "PATTERN",
                "value": "[A-Za-z_][A-Za-z_0-9]*"
              }
            ]
          },
          {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": "`"
              },
              {
                "type": "PATTERN",
                "value": "[A-Za-z_][A-Za-z_0-9]*"
              }
            ]
          }
        ]
      }
    },
    "string": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "\""
          },
          {
            "type": "PATTERN",
            "value": "[^\"]*"
          },
          {
            "type": "STRING",
            "value": "\""
          }
        ]
      }
    },
    "env_path": {
      "type": "PATTERN",
      "value": "\\$[^\\s\\{\\}\\n]*"
    },
    "bare_value": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "PATTERN",
            "value": "[A-Za-z_][A-Za-z_0-9\\[\\]\\+\\-\\.\\/\\^\\'\\*]*"
          },
          {
            "type": "PATTERN",
            "value": "\\d+[A-Za-z][A-Za-z_0-9\\[\\]\\+\\-\\.\\/\\^\\'\\*\\(\\)<>]*"
          }
        ]
      }
    },
    "paren_expr": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "PATTERN",
                "value": "[^()\\{\\}\\n]+"
              },
              {
                "type": "SYMBOL",
                "name": "paren_expr"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": ")"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "IMMEDIATE_TOKEN",
              "content": {
                "type": "PATTERN",
                "value": "[^\\s\\(\\)\\{\\}\\n]+"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "identifier": {
      "type": "PATTERN",
      "value": "`?_?[A-Za-z][A-Za-z_0-9\\[\\]\\+\\-\\.]*"
    },
    "bare_identifier": {
      "type": "PATTERN",
      "value": "[A-Za-z_][A-Za-z_0-9]*"
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "#"
          },
          {
            "type": "PATTERN",
            "value": "[^\\r\\n]*"
          }
        ]
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    },
    {
      "type": "SYMBOL",
      "name": "comment"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}